# Application
PORT=5000
NODE_ENV=development

# Database - MongoDB Atlas or Local
# Local: mongodb://localhost:27017/smart_parking
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGO_URI=your_mongodb_connection_string_here

# JWT Configuration (change JWT_SECRET to a strong random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRE=7d

# Frontend URL for CORS (adjust for production domain)
CLIENT_URL=http://localhost:3000

# Logging Level (debug, info, warn, error)
LOG_LEVEL=debug

# Optional: External Services
SLACK_WEBHOOK_URL=
ADMIN_EMAIL=admin@campus.edu

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Billing Configuration
MIN_BILLING_HOURS=1
RATE_PER_HOUR=20
